FROM nixos/nix:latest

ENV NIX_CONFIG="experimental-features = nix-command flakes"
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV UV_PYTHON=python3.14
ENV UV_PYTHON_DOWNLOADS=never
ENV PY_APP1_PORT=8100

WORKDIR /workspace

COPY . .

RUN nix develop .#py-app1-container -c uv sync --frozen --package py-app1

WORKDIR /workspace/projects/py-app1

EXPOSE 8100

CMD ["nix", "develop", ".#py-app1-container", "-c", "bash", "-lc", "uv run --frozen fastapi run app/main.py --host 0.0.0.0 --port ${PY_APP1_PORT:-8100}"]
